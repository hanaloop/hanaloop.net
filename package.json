    "fuse.js": "^6.6.2",
    "gray-matter": "^4.0.3",
    "mdx-bundler": "^9.0.1",
    "next": "12.3.0",
    "prism-react-renderer": "^1.3.5",
    "prismjs": "^1.29.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "sharp": "^0.31.0",
    "swagger-ui-react": "^4.14.0",
    "tailwindcss": "^3.1.8"
  },
  "devDependencies": {
    "@types/chalk": "^2.2.0",
    "@types/jest": "^27.4.0",
    "@types/js-yaml": "^4.0.5",
    "@types/lodash.get": "^4.4.6",
    "@types/node": "17.0.8",
    "@types/react": "17.0.38",
    "@types/swagger-ui-react": "^4.1.1",
    "autoprefixer": "^10.4.2",
    "chalk": "^5.0.1",
    "commander": "^9.4.0",
    "esbuild": "^0.15.8",
    "esbuild-runner": "^2.2.1",
    "eslint": "8.23.1",
    "eslint-config-next": "12.3.0",
    "jest": "^29.0.3",
    "js-yaml": "^4.1.0",
    "lodash.get": "^4.4.2",
    "npm-run-all": "^4.1.5",
