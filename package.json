{
  "name": "next-dev-portal",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build && next export",
    "start": "next start",
    "lint": "next lint",
    "test": "jest",
    "content:init": "esr ./tool/ndp-cli.ts content/init",
    "content:syncassets": "esr ./tool/ndp-cli.ts content/syncassets",
    "syncassetsall": "esr ./tool/ndp-cli.ts content/syncassets pages,blog,docs,products",
    "gen:collections": "esr ./tool/ndp-cli.ts content/collections",
    "genall:collections": "esr ./tool/ndp-cli.ts content/collections blog,docs,products,pages",
    "gen:trees": "esr ./tool/ndp-cli.ts content/trees",
    "genall:trees": "esr ./tool/ndp-cli.ts content/trees pages,blog,docs,products",
    "genall": "npm-run-all --parallel genall:*",
    "search:fuse": "esr ./tool/ndp-cli.ts search/fuse pages,blog,docs,products ",
    "contentprep": "npm-run-all --parallel genall:* syncassetsall search:fuse",
    "test:utils": "yarn test -t utils"
  },
  "dependencies": {
    "@headlessui/react": "^1.7.2",
    "@mdx-js/loader": "^2.1.3",
