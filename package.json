{
    "name": "fumadocs-site",
    "version": "0.0.0",
    "private": true,
    "scripts": {
        "normalize:content": "node scripts/normalize-content.mjs",
        "prepare:content": "yarn normalize:content && yarn prepare:docs && yarn prepare:blog-list && yarn prepare:insight-list && fumadocs-mdx",
        "prepare:blog-list": "node scripts/generate-blog-list-json.mjs",
        "prepare:insight-list": "node scripts/generate-insight-list-json.mjs",
        "dev": "yarn prepare:content && next dev -H 0.0.0.0 -p 3000",
        "build": "yarn prepare:content && next build",
        "start": "serve out",
        "types:check": "yarn prepare:content && next typegen && tsc --noEmit",
        "postinstall": "yarn prepare:content",
        "prepare:docs": "node scripts/generate-docs-meta.mjs",
        "lint": "eslint"
    },
    "dependencies": {
        "@mdx-js/react": "^3.1.1",
        "@orama/orama": "^3.1.18",
        "@svgr/webpack": "^8.1.0",
        "clsx": "^2.1.1",
        "framer-motion": "^12.38.0",
        "fumadocs-core": "^16.7.9",
        "fumadocs-mdx": "^14.2.11",
        "fumadocs-ui": "^16.7.9",
        "gray-matter": "^4.0.3",
        "lucide-react": "^1.7.0",
        "mdast-util-to-string": "^4.0.0",
        "next": "^16.2.2",
        "next-intl": "^4.11.0",
        "next-mdx-remote": "^6.0.0",
        "react": "19.2.0",
        "react-dom": "19.2.0",
        "react-fast-marquee": "^1.6.5",
        "reading-time": "^1.5.0",
        "remark-mdx": "^3.1.1",
        "remark-parse": "^11.0.0",
        "serve": "^14.2.6",
        "shiki": "^4.0.2",
        "swiper": "^12.1.3",
        "tailwind-merge": "^3.5.0",
        "unified": "^11.0.5",
        "unist-util-visit": "^5.1.0",
        "yaml": "^2.8.3",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@tailwindcss/postcss": "^4",
        "@types/mdx": "^2.0.13",
        "@types/node": "^20",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "eslint": "^9",
        "eslint-config-next": "16.2.2",
        "tailwindcss": "^4",
        "typescript": "^5"
    }
}
